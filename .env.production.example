# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# WARNING: Never expose this key in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── OpenAI ─────────────────────────────────────────────────────────────────
# Get from: platform.openai.com → API Keys

OPENAI_API_KEY=sk-your-openai-api-key-here

# Daily spending limit in USD (recommended: 5 for launch, increase as needed)
OPENAI_DAILY_BUDGET_USD=5

# ─── Vercel KV (Redis) ──────────────────────────────────────────────────────
# Get from: Vercel Dashboard → Storage → Create KV Database

KV_REST_API_URL=https://your-kv-url.kv.vercel-storage.com
KV_REST_API_TOKEN=your-kv-token-here

# ─── App Configuration ───────────────────────────────────────────────────────
# Set to your actual production domain (no trailing slash)

NEXT_PUBLIC_APP_URL=https://maritimeaiguide.in
NEXT_PUBLIC_APP_ENV=production
